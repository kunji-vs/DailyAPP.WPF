<UserControl x:Class="DailyAPP.WPF.Views.LoginUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DailyAPP.WPF.Views"
             mc:Ignorable="d" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helper="clr-namespace:DailyAPP.WPF.Extensions"
             Height="350" Width="600">
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="Width" Value="600"/>
            <Setter Property="Height" Value="350"/>
            <Setter Property="SizeToContent" Value="WidthAndHeight"/>
            <Setter Property="ResizeMode" Value="NoResize"/>
            <Setter Property="prism:Dialog.WindowStartupLocation" Value="CenterScreen"/>
        </Style>
    </prism:Dialog.WindowStyle>
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Image Width="300" Height="185" Source="/Images/20230217183828_1.jpg" Stretch="Fill"/>
        <!--显示错误提示-->
        <md:Snackbar x:Name="RegLoginBar" Grid.ColumnSpan="2" MessageQueue="{Binding MessageQueue}">
            
        </md:Snackbar>
        
        <md:Transitioner Grid.Column="1" SelectedIndex="{Binding TransitionerSelectedIndex,FallbackValue=0}">
            <!--登录-->
            <md:TransitionerSlide>
                <DockPanel Margin="15" VerticalAlignment="Center">
                    <TextBlock DockPanel.Dock="Top" Text="欢迎使用" FontWeight="Bold" FontSize="22" Margin="0,10"/>
                    <TextBox DockPanel.Dock="Top" Margin="0,10" md:HintAssist.Hint="请输入账号" Text="{Binding Account}" />
                    <!--自定义扩展属性-->
                    <PasswordBox DockPanel.Dock="Top" Margin="0,10" helper:PasswordBoxExtend.BindablePassword="{Binding Password,Mode=TwoWay}" md:HintAssist.Hint="请输入密码" />
                    <Button DockPanel.Dock="Top" Content="登录系统" Command="{Binding LoginCommand}"/>
                    <DockPanel DockPanel.Dock="Top"  Margin="0,5" LastChildFill="False">
                        <TextBlock Text="注册账号" Cursor="Hand">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding ShowRegiest}" CommandParameter="1" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBlock>
                        <TextBlock Text="忘记密码" Cursor="Hand" DockPanel.Dock="Right">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding ForgotPassWord}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBlock>
                    </DockPanel>
                </DockPanel>
            </md:TransitionerSlide>
            <!--注册-->
            <md:TransitionerSlide>
                <DockPanel Margin="15" VerticalAlignment="Center">
                    <TextBlock DockPanel.Dock="Top" Text="注册账号" FontWeight="Bold" FontSize="22" Margin="0,10"/>
                    <TextBox DockPanel.Dock="Top" Margin="0,10" md:HintAssist.Hint="请输入姓名" Text="{Binding AccountInfo.Name}" />
                    <TextBox DockPanel.Dock="Top" Margin="0,10" md:HintAssist.Hint="请输入账号" Text="{Binding AccountInfo.Account}"/>
                    <PasswordBox DockPanel.Dock="Top" Margin="0,10" helper:PasswordBoxExtend.BindablePassword="{Binding AccountInfo.Pwd,Mode=TwoWay}" md:HintAssist.Hint="请输入密码" />
                    <PasswordBox DockPanel.Dock="Top" Margin="0,10" helper:PasswordBoxExtend.BindablePassword="{Binding ConfrimPwd,Mode=TwoWay}" md:HintAssist.Hint="再此输入密码" />
                    <Button Margin="0,5" DockPanel.Dock="Top" Content="注册账号" Command="{Binding RegisterAccount}"/>
                    <Button Margin="0,5" DockPanel.Dock="Top" Style="{StaticResource MaterialDesignOutlinedButton}" Content="返回登录" Command="{Binding ShowRegiest}" CommandParameter="0"/>
                </DockPanel>
            </md:TransitionerSlide>
        </md:Transitioner>
    </Grid>
</UserControl>
