<UserControl x:Class="DailyAPP.WPF.Views.MemoUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DailyAPP.WPF.Views"
             mc:Ignorable="d" 
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="450" d:DesignWidth="800">
    <md:DialogHost>
        <md:DrawerHost IsRightDrawerOpen="{Binding IsRightDrawerOpen}">
            <md:DrawerHost.RightDrawerContent>
                <DockPanel Width="300" LastChildFill="False">
                    <TextBlock Text="添加备忘录" Foreground="White" FontSize="18" FontWeight="Bold" Margin="15,10" DockPanel.Dock="Top"/>
                    <StackPanel Margin="20" DockPanel.Dock="Top">
                        <TextBlock Text="状态" Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox SelectedIndex="0" Margin="0,5" Foreground="White">
                            <ComboBoxItem Content="待办"/>
                            <ComboBoxItem Content="已完成"/>
                        </ComboBox>
                    </StackPanel>
                    <TextBox md:HintAssist.Hint="请输入待办标题" Foreground="White" Margin="20,0" DockPanel.Dock="Top"/>
                    <TextBox md:HintAssist.Hint="请输入待办内容" Foreground="White" Margin="20,10" DockPanel.Dock="Top" MinHeight="100"/>
                    <Button Content="添加" Margin="20,0" DockPanel.Dock="Top" Command="{Binding AddMemoCmm}" />
                </DockPanel>
            </md:DrawerHost.RightDrawerContent>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="15,0,0,0">
                    <TextBox Margin="10,0" VerticalAlignment="Center" md:HintAssist.Hint="请输入备忘录" md:TextFieldAssist.HasClearButton="True"/>
                </StackPanel>
                <Button Content="添加备忘录" Margin="10" HorizontalAlignment="Right" Command="{Binding ShowAddMemoCmm}" />

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                    <ItemsControl Grid.Row="1" HorizontalAlignment="Center" ItemsSource="{Binding MemoList}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel></WrapPanel>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <md:TransitioningContent OpeningEffect="{md:TransitionEffect Kind=FadeIn}">
                                    <Border Background="#1D91FF" CornerRadius="5" Margin="3">
                                        <Grid Width="220" Height="180" MaxWidth="250" Margin="3">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="auto"/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <md:PopupBox HorizontalAlignment="Right" Panel.ZIndex="1">
                                                <Button Content="删除"></Button>
                                            </md:PopupBox>
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" Margin="10,5"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Content}" Foreground="DarkGray" FontWeight="Bold" Margin="10,5"/>
                                            <Canvas ClipToBounds="True" Grid.ColumnSpan="2" Grid.RowSpan="2">
                                                <Border Canvas.Top="10" Canvas.Right="-50" Width="120" Height="120" Background="#FFFFFF" CornerRadius="100" Opacity="0.1"/>
                                                <Border Canvas.Top="80" Canvas.Right="-30" Width="120" Height="120" Background="#FFFFFF" CornerRadius="100" Opacity="0.1"/>
                                            </Canvas>
                                        </Grid>
                                    </Border>
                                </md:TransitioningContent>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </md:DrawerHost>
    </md:DialogHost>
</UserControl>
